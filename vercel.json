{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/imprint", "destination": "/imprint.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" }
  ],
  "redirects": [
    { "source": "/work", "destination": "/imprint", "permanent": true },
    { "source": "/work.html", "destination": "/imprint", "permanent": true },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "imprint.alang.studio" }],
      "destination": "https://alang.studio/imprint",
      "permanent": false
    }
  ]
}
