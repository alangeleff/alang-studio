{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "imprint.alang.studio" }],
      "destination": "https://byimprint.studio",
      "permanent": true
    },
    { "source": "/imprint", "destination": "https://byimprint.studio", "permanent": true },
    { "source": "/work", "destination": "https://byimprint.studio", "permanent": true },
    { "source": "/work.html", "destination": "https://byimprint.studio", "permanent": true }
  ]
}
